{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the Uncrowned King server /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Uncrowned King server",
  "uid": "uncrowned-king-server",
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Ready",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Not ready", "color": "red" }, "1": { "text": "Ready", "color": "green" } } }
          ]
        }
      },
      "targets": [
        { "refId": "A", "expr": "uncrowned_king_server_ready", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 2,
      "title": "Active sessions / handshakes / flows",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "uncrowned_king_server_active_sessions", "legendFormat": "sessions", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "refId": "B", "expr": "uncrowned_king_server_active_handshakes", "legendFormat": "handshakes", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "refId": "C", "expr": "uncrowned_king_server_active_flows", "legendFormat": "flows", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 3,
      "title": "Accepted connections /s",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(uncrowned_king_server_accepted_connections_total[5m]))", "legendFormat": "accepted", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 4,
      "title": "Handshake failures /s by reason",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (reason) (rate(uncrowned_king_server_handshake_failures_total[5m]))", "legendFormat": "{{reason}}", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 5,
      "title": "Rejections /s (limits)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(uncrowned_king_server_rejected_handshakes_total[5m]))", "legendFormat": "handshakes", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "refId": "B", "expr": "sum(rate(uncrowned_king_server_rejected_sessions_total[5m]))", "legendFormat": "sessions", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 6,
      "title": "Relay throughput (bytes/s) by protocol / direction",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        { "refId": "A", "expr": "sum by (protocol, direction) (rate(uncrowned_king_server_relay_bytes_total[5m]))", "legendFormat": "{{protocol}} {{direction}}", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 7,
      "title": "Flow opens vs failures /s",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(uncrowned_king_server_flow_open_requests_total[5m]))", "legendFormat": "requests", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "refId": "B", "expr": "sum(rate(uncrowned_king_server_flow_open_failures_total[5m]))", "legendFormat": "failures", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "id": 8,
      "title": "Config reloads (success / failure, 1h)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "targets": [
        { "refId": "A", "expr": "increase(uncrowned_king_server_config_reload_successes_total[1h])", "legendFormat": "success", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "refId": "B", "expr": "increase(uncrowned_king_server_config_reload_failures_total[1h])", "legendFormat": "failure", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    }
  ]
}
